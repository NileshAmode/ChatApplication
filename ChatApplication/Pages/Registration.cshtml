@page
@model ChatApplication.Pages.RegistrationModel
@{
    ViewData["Title"] = "Register";
    Layout = null;
}
<link rel="stylesheet" href="~/css/Registration.css" />
<div class="container">
    <div class="card">
        <h2>User Registration</h2>

        <form method="post" onsubmit="return validateForm();">

            <div class="row">
                <div class="form-group">
                    <label>First Name</label>
                    <input type="text" id="FirstName" asp-for="__customerEntity.FirstName" />
                </div>
                <div class="form-group">
                    <label>Middle Name</label>
                    <input type="text" id="Middle" asp-for="__customerEntity.MiddleName" />
                </div>
                <div class="form-group">
                    <label>Last Name</label>
                    <input type="text" id="LastName" asp-for="__customerEntity.LastName" />
                </div>
            </div>

            <div class="row">
                <div class="form-group">
                    <label>Email</label>
                    <input type="text" id="Email" asp-for="__customerEntity.Email" />
                </div>
                <div class="form-group">
                    <label>Mobile No</label>
                    <input type="text" id="Mobile" asp-for="__customerEntity.MobileNo" maxlength="10" />
                </div>
            </div>

            <div class="row">
                <div class="form-group">
                    <label>Gender</label>
                    <select id="Gender" asp-for="__customerEntity.Gender">
                        <option value="">-- Select Gender --</option>
                        <option>Male</option>
                        <option>Female</option>
                        <option>Other</option>
                    </select>
                </div>
                <div class="form-group">
                    <label>Country</label>
                    <select id="Country" asp-for="__customerEntity.Country">
                        <option value="">-- Select Country --</option>
                        <option>India</option>
                        <option>USA</option>
                        <option>Other</option>
                    </select>
                </div>
            </div>

            <div class="row">
                <div class="form-group">
                    <label>City</label>
                    <input type="text" id="City" asp-for="__customerEntity.City" />
                </div>
                <div class="form-group">
                    <label>State</label>
                    <input type="text" id="State" asp-for="__customerEntity.State" />
                </div>
                <div class="form-group">
                    <label>Pincode</label>
                    <input type="text" id="Pincode" asp-for="__customerEntity.Pincode" maxlength="6" />
                </div>
            </div>

            <div class="form-group">
                <label>Address</label>
                <input type="text" id="Address" asp-for="__customerEntity.Address" />
            </div>

            <div class="row">
                <div class="form-group">
                    <label>Password</label>
                    <input type="password" id="Password" asp-for="__customerEntity.Password" />
                </div>
                <div class="form-group">
                    <label>Confirm Password</label>
                    <input type="password" id="ConfirmPassword" name="ConfirmPassword" />
                </div>
            </div>

            <button type="submit">Register</button>

            <div id="errorBox" class="msg error"></div>

        </form>

       
    </div>
</div>
  <script>
       function ValidateForm()
       {
            var errorBox = document.getElementById("errorBox");
            errorBox.innerText = "";

           var firstName = document.getElementById("FirstName").value.trim();
           var lastName = document.getElementById("LastName").value.trim();
           var email = document.getElementById("Email").value.trim();
           var mobile = document.getElementById("Mobile").value.trim();
           var gender = document.getElementById("Gender").value;
           var country = document.getElementById("Country").value;
           var city = document.getElementById("City").value.trim();
           var state = document.getElementById("State").value.trim();
           var pincode = document.getElementById("Pincode").value.trim();
           var address = document.getElementById("Address").value.trim();
           var password = document.getElementById("Password").value;
           var confirmPassword = document.getElementById("ConfirmPassword").value;

            if (firstName === "") { errorBox.innerText = "First Name required"; return false; }
            if (lastName === "") { errorBox.innerText = "Last Name required"; return false; }
            if (!/^\d{10}$/.test(mobile)) { errorBox.innerText = "Mobile must be 10 digits"; return false; }
            if (!gender) { errorBox.innerText = "Select Gender"; return false; }
            if (!country) { errorBox.innerText = "Select Country"; return false; }
            if (city === "") { errorBox.innerText = "City required"; return false; }
            if (state === "") { errorBox.innerText = "State required"; return false; }
            
            if (!/^\d{6}$/.test(pincode)) { errorBox.innerText = "Pincode must be 6 digits"; return false; }
            if (address === "") { errorBox.innerText = "Address required"; return false; }
            
            if (password === "") { errorBox.innerText = "Password required"; return false; }
            if (password !== confirmPassword) {
                errorBox.innerText = "Password & Confirm Password must match";
                return false;
            }

          return true;
       }
  </script>